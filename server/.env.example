# LLM
AAX_ANTHROPIC_API_KEY=sk-ant-...
AAX_OPENAI_API_KEY=sk-...
AAX_DEFAULT_LLM=claude

# LangSmith (optional, enables tracing)
AAX_LANGCHAIN_TRACING_V2=false
AAX_LANGCHAIN_API_KEY=
AAX_LANGCHAIN_PROJECT=aax-exchange

# Firebase / Firestore
AAX_GOOGLE_CLOUD_PROJECT=your-gcp-project
AAX_FIRESTORE_DATABASE=(default)

# GCS
AAX_GCS_BUCKET_NAME=aax-assets
